+ * block without an in-function `extern "C"` (illegal in C++). */
+extern "C" int claude_rpc_trace_bp_hook (int slot, uae_u32 pc);
+
+/* claude_rpc: arm the BP machinery from outside debug.cpp.  The
+ * in-process debugger normally sets `do_skip = 1` + SPCFLAG_BRK when
+ * the user types `g` to resume from a paused state.  When the RPC
+ * client installs a BP without ever entering the debugger, that
+ * priming step never happens, and the CPU loop never calls debug() to
+ * check BPs.  This helper wires it up so externally-installed BPs fire
+ * normally. */
+extern "C" void claude_rpc_arm_bp_skip (void)
+{
+	do_skip = 1;
+	debugging = 1;
+	set_special (SPCFLAG_BRK);
+}
